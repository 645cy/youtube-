# TubeFactory OCP Environment
# Copy this file to .env and fill values as needed.

# Runtime
ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1

AUTO_SEED_ON_STARTUP=false
START_SCHEDULER_ON_STARTUP=false
HEALTH_CHECK_YOUTUBE_QUOTA=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/tubefactory.db
ECHO_SQL=false

# YouTube API
# Optional. If empty, the app will use yt-dlp / web fallback where possible.
YOUTUBE_API_KEY=
FORCE_YTDLP_MODE=false
API_QUOTA_LIMIT=10000

# Crawler safety limits
CRAWLER_MIN_DELAY_MS=1500
CRAWLER_MAX_DELAY_MS=4500
CRAWLER_MAX_RETRIES=5
CRAWLER_MAX_CONCURRENCY=3
CRAWLER_MAX_REQ_PER_MINUTE=15
CRAWLER_PROXY_LIST=

# Business defaults
DEFAULT_NICHE=ai_tools
DEFAULT_TARGET_REGION=global
DEFAULT_VIDEO_TYPE=tutorial
DEFAULT_CRAWLER_TASK_TYPE=channel_latest
DEFAULT_CRAWLER_FREQUENCY=manual
DEFAULT_MONITOR_FREQUENCY=daily
CRAWLER_DEFAULT_MAX_RESULTS=10
RADAR_TRIGGER_MAX_RESULTS=5
ANALYSIS_REMOTE_COMMENTS_LIMIT=20

# Frontend
# Public API base for browser requests, e.g. http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_PREFIX=/api/v1
# Optional internal base for Next.js dev rewrites, e.g. http://127.0.0.1:8000
BACKEND_INTERNAL_URL=
NEXT_PUBLIC_DEFAULT_NICHE=ai_tools
NEXT_PUBLIC_DEFAULT_TARGET_REGION=global
NEXT_PUBLIC_DEFAULT_VIDEO_TYPE=tutorial
NEXT_PUBLIC_DEFAULT_CRAWLER_TASK_TYPE=channel_latest
NEXT_PUBLIC_DEFAULT_CRAWLER_FREQUENCY=manual
NEXT_PUBLIC_DEFAULT_MONITOR_FREQUENCY=daily
